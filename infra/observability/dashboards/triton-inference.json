{
  "uid": "uap-triton-inference",
  "title": "Triton Inference",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "text",
      "title": "Inference Plane",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 0 },
      "options": {
        "mode": "markdown",
        "content": "Reserved for Triton, TensorRT-LLM, ASR and TTS model latency, quotas and graceful degradation posture."
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Triton Reachability",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 0 },
      "datasource": "Prometheus",
      "targets": [{ "expr": "sum(up{job=~\".*triton.*\"})", "refId": "A" }],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        },
        "overrides": []
      }
    }
  ]
}
