{
  "realm": "uap",
  "enabled": true,
  "clients": [
    {
      "clientId": "uap-chat-web",
      "enabled": true,
      "publicClient": true,
      "redirectUris": [
        "http://localhost:3200/*",
        "http://chat.uap.localtest.me:8088/*",
        "http://*.sslip.io:8088/*",
        "http://*.nip.io:8088/*"
      ],
      "webOrigins": [
        "http://localhost:3200",
        "http://chat.uap.localtest.me:8088",
        "http://chat.127.0.0.1.sslip.io:8088"
      ]
    },
    {
      "clientId": "uap-admin-web",
      "enabled": true,
      "publicClient": true,
      "redirectUris": [
        "http://localhost:3300/*",
        "http://admin.uap.localtest.me:8088/*",
        "http://*.sslip.io:8088/*",
        "http://*.nip.io:8088/*"
      ],
      "webOrigins": [
        "http://localhost:3300",
        "http://admin.uap.localtest.me:8088",
        "http://admin.127.0.0.1.sslip.io:8088"
      ]
    }
  ],
  "users": [
    {
      "username": "admin",
      "enabled": true,
      "credentials": [{ "type": "password", "value": "admin", "temporary": false }]
    }
  ]
}
