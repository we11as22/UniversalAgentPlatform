{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "preserve",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@uap/ui/*": ["packages/ui/src/*"],
      "@uap/ts-sdk/*": ["packages/ts-sdk/src/*"],
      "@uap/config/*": ["packages/config/src/*"],
      "@uap/auth/*": ["packages/auth/src/*"],
      "@uap/observability/*": ["packages/observability/src/*"]
    }
  }
}

